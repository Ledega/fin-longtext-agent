# =============================================================================
# 金融长文本 Agent - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# =============================================================================

# DashScope API Key（调用 Embedding 和 Qwen 模型必需）
# 获取方式：阿里云百炼控制台 → API-KEY 管理
DASHSCOPE_API_KEY="your-api-key-here"

# Embedding 模型（默认 text-embedding-v3）
# EMBEDDING_MODEL="text-embedding-v3"

# Qwen 模型（默认 qwen3.7-plus）
# QWEN_MODEL="qwen3.7-plus"

# 数据库路径（默认 data/fin_longtext.db）
# DB_PATH="data/fin_longtext.db"